# Local development example for the Vercel-ready architecture

NODE_ENV=development
PORT=3000
HOST=localhost

NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
JWT_SECRET=replace-me

# Postgres
DATABASE_URL=postgresql://user:password@localhost:5432/english_listening_trainer
POSTGRES_PRISMA_URL=postgresql://user:password@localhost:5432/english_listening_trainer
POSTGRES_URL_NON_POOLING=postgresql://user:password@localhost:5432/english_listening_trainer

# Cerebras
CEREBRAS_API_KEY=your-cerebras-key
CEREBRAS_BASE_URL=https://api.cerebras.ai
AI_TIMEOUT=30000
AI_MAX_RETRIES=3
AI_DEFAULT_MODEL=gpt-oss-120b
AI_DEFAULT_TEMPERATURE=0.7

# Together TTS
ENABLE_TTS=true
TOGETHER_API_KEY=your-together-key
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_TTS_MODEL=hexgrad/Kokoro-82M
TTS_TIMEOUT=60000
TTS_MAX_CONCURRENT=1
TTS_QUEUE_LIMIT=8

# Optional proxy settings
# CEREBRAS_PROXY_URL=http://127.0.0.1:10808
# TOGETHER_PROXY_URL=http://127.0.0.1:10808
# RSS_PROXY_URL=http://127.0.0.1:10808
# PROXY_URL=http://127.0.0.1:10808
# HTTPS_PROXY=http://127.0.0.1:10808
# HTTP_PROXY=http://127.0.0.1:10808

# Blob + cron
BLOB_READ_WRITE_TOKEN=your-blob-token
CRON_SECRET=replace-me

# Optional search enhancement
EXA_API_KEY=your-exa-key

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_NAME=System Administrator
ADMIN_DEMO_DATA=0
