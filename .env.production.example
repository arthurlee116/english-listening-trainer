# Production example for Vercel

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-production-domain.vercel.app
APP_BASE_URL=https://your-production-domain.vercel.app
JWT_SECRET=replace-me

# Postgres
DATABASE_URL=postgresql://...
POSTGRES_PRISMA_URL=postgresql://...
POSTGRES_URL_NON_POOLING=postgresql://...

# Cerebras
CEREBRAS_API_KEY=...
CEREBRAS_BASE_URL=https://api.cerebras.ai
AI_TIMEOUT=30000
AI_MAX_RETRIES=3
AI_DEFAULT_MODEL=gpt-oss-120b
AI_DEFAULT_TEMPERATURE=0.7

# Together
ENABLE_TTS=true
TOGETHER_API_KEY=...
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_TTS_MODEL=hexgrad/Kokoro-82M
TTS_TIMEOUT=60000
TTS_MAX_CONCURRENT=1
TTS_QUEUE_LIMIT=8

# Optional proxy settings
# CEREBRAS_PROXY_URL=http://127.0.0.1:10808
# TOGETHER_PROXY_URL=http://127.0.0.1:10808
# RSS_PROXY_URL=http://127.0.0.1:10808
# PROXY_URL=http://127.0.0.1:10808
# HTTPS_PROXY=http://127.0.0.1:10808
# HTTP_PROXY=http://127.0.0.1:10808

# Blob + cron
BLOB_READ_WRITE_TOKEN=...
CRON_SECRET=replace-me

# Optional search enhancement
EXA_API_KEY=...

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_NAME=System Administrator
ADMIN_DEMO_DATA=0
